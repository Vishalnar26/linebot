  "host_os": "Ubuntu (latest version)",
  "workspace_name": "linebot_ws",
  "package_name": "line_follower",
  "topics": "/sensor_data, /cmd_vel, /line_error, /odm",
  "arduino_library": "micro_ros_arduino or rosserial_arduino",
  "control_algorithm": "PID",
  "pid_params": "TBD",
